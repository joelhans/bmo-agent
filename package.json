{
  "name": "bmo-agent",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --compile --outfile dist/bmo",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "smoke": "bash scripts/smoke-test.sh",
    "install": "bash scripts/install.sh"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.50.8",
    "openai": "^6.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "^1.3.8"
  }
}
