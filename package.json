{
  "name": "bmo-agent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node index.mjs",
    "start:watch": "node --watch index.mjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:cli": "bun build index.mjs --compile --outfile dist/bmo",
    "install-cli": "pnpm run build:cli && rm -rf ~/.local/bin/bmo-tools && mkdir -p ~/.local/bin/bmo-tools && cp dist/bmo ~/.local/bin/bmo && chmod +x ~/.local/bin/bmo && cp -r tools/* ~/.local/bin/bmo-tools/ && echo 'Installed bmo to ~/.local/bin/bmo (tools in ~/.local/bin/bmo-tools/)'"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "neo-blessed": "^0.2.0",
    "openai": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "typescript": "^4.4.4"
  },
  "alias": {
    "term.js": "./shims/term.js/index.js",
    "pty.js": "./shims/pty.js/index.js",
    "neo-blessed/lib/widgets/terminal.js": "./shims/neo-blessed/terminal.js",
    "neo-blessed/lib/widget.js": "./shims/neo-blessed/widget.js",
    "neo-blessed/lib/blessed.js": "./shims/neo-blessed/blessed.js",
    "neo-blessed": "neo-blessed/lib/blessed.js"
  },
  "packageManager": "pnpm@9.14.2+sha512.6e2baf77d06b9362294152c851c4f278ede37ab1eba3a55fda317a4a17b209f4dbb973fb250a77abc463a341fcb1f17f17cfa24091c4eb319cda0d9b84278387"
}
