set -euo pipefail
LOG_DIR="logs"
BASE_DIR="$HOME/.local/share/bmo"
mkdir -p "$LOG_DIR"
# Extract unique referenced .log paths (handle cases like `...log`+`...log`)
mapfile -t refs < <(grep -oE "([A-Za-z0-9_.-]+/)*agent-[0-9TZ:-]+\.log" CAPTAINS_LOG.md | sort -u)

copied=()
resolved=()
skipped=()
for ref in "${refs[@]}"; do
  src=""
  # Direct path under BASE
  if [[ -f "$BASE_DIR/$ref" ]]; then
    src="$BASE_DIR/$ref"
  else
    # Search by basename
    bn="$(basename "$ref")"
    # Gather candidates
    mapfile -t candidates < <(find "$BASE_DIR" -type f -name "$bn" 2>/dev/null || true)
    if (( ${#candidates[@]} == 1 )); then
      src="${candidates[0]}"
    elif (( ${#candidates[@]} > 1 )); then
      # Prefer candidate whose trailing path matches the reference
      match_candidates=()
      for c in "${candidates[@]}"; do
        # strip BASE_DIR prefix
        rel="${c#$BASE_DIR/}"
        if [[ "$rel" == *"$ref" ]]; then
          match_candidates+=("$c")
        fi
      done
      if (( ${#match_candidates[@]} == 1 )); then
        src="${match_candidates[0]}"
      fi
    fi
  fi

  if [[ -n "$src" ]]; then
    install -m 0644 -D "$src" "$LOG_DIR/$(basename "$src")"
    copied+=("$ref -> $(basename "$src")")
    resolved+=("$ref => ${src#$BASE_DIR/}")
  else
    skipped+=("$ref")
  fi
done

{
  echo "REFERENCES:"; printf "- %s\n" "${refs[@]}"
  echo
  echo "RESOLVED PATHS:"; printf "- %s\n" "${resolved[@]}"
  echo
  echo "COPIED:"; printf "- %s\n" "${copied[@]}"
  echo
  echo "SKIPPED (not found or ambiguous):"; printf "- %s\n" "${skipped[@]}"
  echo
  echo "logs/ contents:"; ls -1 "$LOG_DIR" | sed "s/^/logs\//"
} | sed "s/^/\x1b[1m/;s/$/\x1b[0m/" | sed "s/\x1b\[[0-9;]*m//g"
