set -euo pipefail
BASE_DIR="$HOME/.local/share/bmo"
LOG_DIR="logs"
mkdir -p "$LOG_DIR"

# Extract unique referenced .log paths
REFS_FILE=".bmo_tmp_refs"; COPIED_FILE=".bmo_tmp_copied"; MISSING_FILE=".bmo_tmp_missing"
: > "$REFS_FILE"; : > "$COPIED_FILE"; : > "$MISSING_FILE"

grep -oE "([A-Za-z0-9_.-]+/)*agent-[0-9TZ:-]+\.log" CAPTAINS_LOG.md | sort -u > "$REFS_FILE" || true

while IFS= read -r ref; do
  [ -z "$ref" ] && continue
  src="$BASE_DIR/$ref"
  if [ -f "$src" ]; then
    cp -f "$src" "$LOG_DIR/$(basename "$ref")"
    echo "$ref" >> "$COPIED_FILE"
  else
    echo "$ref" >> "$MISSING_FILE"
  fi
done < "$REFS_FILE"

# Output summary
echo "References found:"; cat "$REFS_FILE" | sed 's/^/- /' || true
printf "\nCopied (exist in %s):\n" "$BASE_DIR"; cat "$COPIED_FILE" | sed 's/^/- /' || echo "- (none)"
printf "\nMissing (not found under %s):\n" "$BASE_DIR"; cat "$MISSING_FILE" | sed 's/^/- /' || echo "- (none)"
printf "\nlogs/ contents:\n"; ls -1 "$LOG_DIR" 2>/dev/null | sed 's/^/logs\//'

# Cleanup temp files
rm -f "$REFS_FILE" "$COPIED_FILE" "$MISSING_FILE"
' reason=Copy referenced logs that actually exist under ~/.local/share/bmo into ./logs and report results
