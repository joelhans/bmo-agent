with open("CAPTAINS_LOG.md", "r", encoding="utf-8") as f:
    text = f.read()

# Extract referenced .log paths
pattern = re.compile(r"(?:[A-Za-z0-9_.-]+/)*agent-[0-9T:-]+\.log")
refs = sorted(set(pattern.findall(text)))

copied = []
resolved = []
skipped = []
missing = []
ambiguous = []

# Index all log files under base by basename for fallback search
all_candidates = {}
for root, dirs, files in os.walk(base):
    for name in files:
        if name.endswith('.log'):
            all_candidates.setdefault(name, []).append(os.path.join(root, name))

for ref in refs:
    src = None
    direct = os.path.join(base, ref)
    if os.path.isfile(direct):
        src = direct
    else:
        bn = os.path.basename(ref)
        cands = all_candidates.get(bn, [])
        if len(cands) == 1:
            src = cands[0]
        elif len(cands) > 1:
            # Prefer candidate whose relpath endswith the ref
            def rel(p):
                rp = os.path.relpath(p, base)
                return rp.replace('\\', '/')
            matching = [c for c in cands if rel(c).endswith(ref)]
            if len(matching) == 1:
                src = matching[0]
            else:
                ambiguous.append(ref)
    if src:
        dest = os.path.join(log_dir, os.path.basename(src))
        shutil.copy2(src, dest)
        copied.append(f"{ref} -> {os.path.basename(src)}")
        resolved.append(f"{ref} => {os.path.relpath(src, base)}")
    else:
        missing.append(ref)

print("REFERENCES:")
for r in refs:
    print("-", r)
print()
print("RESOLVED PATHS:")
for r in resolved:
    print("-", r)
print()
print("COPIED:")
for c in copied:
    print("-", c)
print()
print("AMBIGUOUS (skipped):")
for a in ambiguous:
    print("-", a)
print()
print("MISSING (not found):")
for m in missing:
    print("-", m)
print()
print("logs/ contents:")
for name in sorted(os.listdir(log_dir)):
    print("logs/" + name)
